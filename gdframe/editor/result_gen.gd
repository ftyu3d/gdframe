extends RefCounted
## 生成 [member GDFrameConfig.RESULT_SCRIPT_PATH]：核心 [code]ERR_SAVE_*[/code] + 各扩展 [code]result_constants()[/code] + 固定 helpers。

const _MODULE_SCAN: Script = preload("res://addons/gdframe/runtime/ext/module_scan.gd")
const _MODULE_EDITOR_SCAN: Script = preload("res://addons/gdframe/editor/module_editor_scan.gd")

const _CORE_SECTIONS: Array[Dictionary] = [
	{
		"title": "Save（[method GDFrame.save_flush] / [method GDFrame.save_read_game_resource] 等）",
		"names": [
			"ERR_SAVE_WRITE_FAILED",
			"ERR_SAVE_SLOT_ID_INVALID",
			"ERR_SAVE_SLOT_NOT_FOUND",
			"ERR_SAVE_READ_FAILED",
			"ERR_SAVE_PROFILE_READ_FAILED",
			"ERR_SAVE_CORRUPTED",
			"ERR_SAVE_DELETE_FAILED",
			"ERR_SAVE_META_WRITE_FAILED",
		],
	},
]


static func generate_all() -> Dictionary:
	return generate_from_modules(_MODULE_SCAN.load_modules())


static func generate_from_modules(modules: Array[Script]) -> Dictionary:
	var content: String = _build_source(modules)
	if content.is_empty():
		return {
			"ok": false,
			"changed": false,
			"message": "GDFrameResult 生成内容无效。",
			"content": "",
		}
	var ext_count: int = _count_ext_constants(modules)
	var changed: bool = _should_write(content)
	var msg: String
	if changed:
		msg = "已生成 %s（含 %d 个扩展错误码常量）。" % [
			GDFrameConfig.RESULT_SCRIPT_PATH,
			ext_count,
		]
		if ext_count == 0:
			msg = "已生成 %s（仅核心 ERR_SAVE_*）。" % GDFrameConfig.RESULT_SCRIPT_PATH
	else:
		msg = "GDFrameResult 已是最新（%d 个扩展错误码常量）。" % ext_count
	return {
		"ok": true,
		"changed": changed,
		"message": msg,
		"content": content,
	}


static func _count_ext_constants(modules: Array[Script]) -> int:
	var count: int = 0
	for mod: Script in modules:
		var raw: Variant = _MODULE_EDITOR_SCAN.call_editor_method(mod, &"result_constants")
		if raw is Array:
			count += (raw as Array).size()
	return count


static func _should_write(content: String) -> bool:
	var abs_path: String = ProjectSettings.globalize_path(GDFrameConfig.RESULT_SCRIPT_PATH)
	if not FileAccess.file_exists(abs_path):
		return true
	return FileAccess.get_file_as_string(abs_path) != content


static func _build_source(modules: Array[Script]) -> String:
	var lines: PackedStringArray = PackedStringArray()
	lines.append("## Auto-generated by GDFrame — do not edit manually.")
	lines.append("class_name GDFrameResult")
	lines.append("extends RefCounted")
	lines.append("")
	lines.append("# =============================================================================")
	lines.append("# Success")
	lines.append("# =============================================================================")
	lines.append("")
	lines.append("## 操作成功。")
	lines.append("const OK: StringName = &\"\"")
	lines.append("")
	for section: Dictionary in _CORE_SECTIONS:
		lines.append("# =============================================================================")
		lines.append("# %s" % str(section.get("title", "Errors")))
		lines.append("# =============================================================================")
		lines.append("")
		lines.append(
			"# 失败值为全大写 [code]ERR_*[/code] 文案 key；提示用 [code]tr(String(err))[/code]。"
		)
		lines.append("")
		for name: String in section.get("names", []):
			lines.append("const %s: StringName = &\"%s\"" % [name, name])
		lines.append("")
	var ext_sections: Array[Dictionary] = _collect_ext_sections(modules)
	for ext_section: Dictionary in ext_sections:
		lines.append("# =============================================================================")
		lines.append("# %s" % str(ext_section.get("title", "Extension errors")))
		lines.append("# =============================================================================")
		lines.append("")
		for name: String in ext_section.get("names", []):
			lines.append("const %s: StringName = &\"%s\"" % [name, name])
		lines.append("")
	lines.append(_helpers_block())
	return "\n".join(lines) + "\n"


static func _collect_ext_sections(modules: Array[Script]) -> Array[Dictionary]:
	var out: Array[Dictionary] = []
	var seen: Dictionary = {}
	for mod: Script in modules:
		var raw: Variant = _MODULE_EDITOR_SCAN.call_editor_method(mod, &"result_constants")
		if raw == null or not raw is Array:
			continue
		var names: PackedStringArray = PackedStringArray()
		for entry: Variant in raw:
			var const_name: String = _entry_name(entry)
			if const_name.is_empty():
				continue
			if seen.has(const_name):
				push_warning(
					"GDFrameResult: 错误码常量冲突 %s（模块 %s）"
					% [const_name, mod.resource_path.get_base_dir().get_file()]
				)
				continue
			seen[const_name] = true
			names.append(const_name)
		if names.is_empty():
			continue
		var module_id: String = mod.resource_path.get_base_dir().get_file()
		out.append({
			"title": "扩展 %s（ext/%s）" % [module_id, module_id],
			"names": names,
		})
	return out


static func _entry_name(entry: Variant) -> String:
	if entry is String:
		return String(entry).strip_edges()
	if entry is Dictionary:
		return str(entry.get("name", "")).strip_edges()
	return ""


static func _helpers_block() -> String:
	return (
		"# =============================================================================\n"
		+ "# Helpers\n"
		+ "# =============================================================================\n"
		+ "\n"
		+ "\n"
		+ "## 成功时 [param err] 为空 [StringName]（[member OK]）；"
		+ "勿用 [code]==[/code] 直接比 [member OK]，用本方法或 [method is_error]。\n"
		+ "static func is_ok(err: StringName) -> bool:\n"
		+ "\treturn String(err).is_empty()\n"
		+ "\n"
		+ "\n"
		+ "static func is_error(err: StringName) -> bool:\n"
		+ "\treturn not is_ok(err)\n"
		+ "\n"
		+ "\n"
		+ "## [method GDFrame.save_read_game_resource] 返回字典中的 Resource；失败为 [code]null[/code]。\n"
		+ "static func read_resource(result: Dictionary) -> Resource:\n"
		+ "\tvar res: Variant = result.get(\"resource\")\n"
		+ "\treturn res as Resource if res is Resource else null\n"
		+ "\n"
		+ "\n"
		+ "static func read_error(result: Dictionary) -> StringName:\n"
		+ "\tvar err: Variant = result.get(\"error\", OK)\n"
		+ "\treturn err if err is StringName else OK\n"
	)
